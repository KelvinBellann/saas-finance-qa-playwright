{
  "name": "saas-finance-qa-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Projeto sênior de automação para um SaaS financeiro com Playwright 1.59.1, TypeScript, API tests e K6.",
  "type": "module",
  "scripts": {
    "app:dev": "cross-env NODE_ENV=development tsx watch src/app/server.ts",
    "app:start": "cross-env NODE_ENV=development tsx src/app/server.ts",
    "app:start:test": "cross-env NODE_ENV=test TEST_MODE=true tsx src/app/server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf playwright-report test-results artifacts",
    "pw:install": "playwright install chromium firefox webkit",
    "test": "npm run test:all",
    "test:all": "npm run test:e2e && npm run test:api",
    "test:e2e": "playwright test tests/e2e",
    "test:security": "playwright test --project=security-api --project=security-ui",
    "test:e2e:headed": "playwright test tests/e2e --project=chromium --headed",
    "test:e2e:ci": "playwright test tests/e2e",
    "test:api": "playwright test tests/api --project=api",
    "report:open": "playwright show-report",
    "perf:smoke": "k6 run --summary-export=artifacts/k6/smoke-summary.json performance/smoke/transactions-smoke.js",
    "perf:load": "k6 run --summary-export=artifacts/k6/load-summary.json performance/load/transactions-load.js"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "automation",
    "k6",
    "portfolio"
  ],
  "author": "Kelvin + Codex",
  "license": "MIT",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4"
  }
}
